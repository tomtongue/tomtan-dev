---
interface Props {
    variant?: 'offset' | 'small';
}

const { variant } = Astro.props;
---

<div class="grid-container">
    <ul class:list={['blog-grid', { offset: variant === 'offset', small: variant === 'small' }]}>
        <slot />
    </ul>
</div>

<style>
/* グリッドコンテナ */
.grid-container {
    width: 100%;
    max-width: var(--content-width, 75rem);
    margin: 0 auto;
    padding: 0 var(--content-padding, 2rem);
}

/* ブロググリッドのベースレイアウト */
.blog-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr)); /* 2列レイアウトを強制 */
    gap: 2.5rem;
    list-style: none;
    padding: 0;
    margin: 2rem 0;
    width: 100%;
}

/* レスポンシブデザイン */
@media (max-width: 1024px) {
    .blog-grid {
        gap: 2rem;
    }
}

@media (max-width: 768px) {
    .blog-grid {
        grid-template-columns: 1fr; /* モバイルでは1列 */
        gap: 1.5rem;
    }
    
    .grid-container {
        padding: 0 1rem;
    }
}
</style>